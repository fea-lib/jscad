{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "allowArbitraryExtensions": true,
    "paths": {
      "@fea-lib/values": ["../values/src/index.ts"]
    }
  },
  "include": ["src", "__tests__"]
}
